# Server-only (API) storage for the MFE mapping
#
# Recommended for Vercel / PROD: PostgreSQL
# When DATABASE_URL is set, the API stores the mapping in PostgreSQL.
DATABASE_URL=

# Alternative (non-Vercel): file path for mapping JSON
# Only use this if you have a persistent writable disk (e.g., a mounted volume).
#
# Linux/macOS example:
# MFE_MAPPING_PATH=/var/lib/app/mfe-mapping.json
#
# Windows example:
# MFE_MAPPING_PATH=C:\\data\\mfe-mapping.json
MFE_MAPPING_PATH=
